# Copy to /opt/the_direction/.env on the VM (never commit real secrets).

# API listen (Express)
PORT=8787
# Optional override; default 0.0.0.0 binds all interfaces (needed on a VM).
# HOST=0.0.0.0

# Binance (match what you use locally)
# BINANCE_USE_TESTNET=false
# BINANCE_FUTURES_BASE=https://fapi.binance.com
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# Supabase (for Agent 1 settings persistence)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# Throttle / spike backtest tuning (optional)
# BINANCE_FUTURES_WEIGHT_BUDGET_RATIO=0.45
# BINANCE_FUTURES_MIN_REQUEST_GAP_MS=25
# SPIKE_TPSL_V3_CONCURRENCY=2
# SPIKE_TPSL_V3_MAX_SYMBOLS=80
# SPIKE_TPSL_V3_PAGE_DELAY_MS=0

# 5m universe screener (Test Page): default max symbols 600, hard cap 800; parallel fetches.
# FIVEMIN_SCREENER_MAX_SYMBOLS=600
# FIVEMIN_SCREENER_CONCURRENCY=18

# Agent 1 automated 5m spike scan (requires Supabase + run supabase/agent1_spikes.sql). Omit or any value except false enables the scheduler.
# AGENT1_SCAN_SCHEDULER=false
# Agent 1 execution loop (requires BINANCE keys + run supabase/agent1_execution.sql)
# AGENT1_EXECUTION_ENABLED=false
# AGENT1_EXECUTION_POLL_MS=15000
# AGENT1_EXECUTION_MAX_SPIKES_PER_TICK=8
# Optional: max age (ms) for a pending spike before execution skips it (default: scan interval + 2m).
# AGENT1_EXECUTION_MAX_SPIKE_AGE_MS=
# AGENT1_EXECUTION_SINGLE_WRITER=true
# AGENT1_EXECUTION_LOCK_NAME=agent1_execution_main
# AGENT1_EXECUTION_LOCK_TTL_SEC=90
# AGENT1_EXECUTION_WRITER_ID=gce-execution

# 5m long simulation (shadow): market-wide by default (same volume universe + scanMaxSymbols / min quote vol as Agent 1 settings).
# AGENT1_SHADOW_MARKET_WIDE=false
# AGENT1_SHADOW_SYMBOL=BLESSUSDT
# AGENT1_SHADOW_BARS=1000
# AGENT1_SHADOW_CONCURRENCY=18
# AGENT1_SHADOW_SCHEDULER=false
# AGENT1_SHADOW_SINGLE_WRITER=true
# AGENT1_SHADOW_LOCK_NAME=agent1_shadow_main
# AGENT1_SHADOW_LOCK_TTL_SEC=90
# AGENT1_SHADOW_WRITER_ID=gce-main

# Local-dev safety (recommended when production is using the same Supabase):
# AGENT1_SHADOW_SCHEDULER=false
