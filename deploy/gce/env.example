# Copy to /opt/the_direction/.env on the VM (never commit real secrets).

# API listen (Express)
PORT=8787
# Optional override; default 0.0.0.0 binds all interfaces (needed on a VM).
# HOST=0.0.0.0

# Binance (match what you use locally)
# BINANCE_USE_TESTNET=false
# BINANCE_FUTURES_BASE=https://fapi.binance.com
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# Optional: per-subaccount routing (see agent_settings.binance_account: master | sub1 | sub2).
# master uses BINANCE_MASTER_* if set, else BINANCE_API_KEY / BINANCE_API_SECRET above.
# BINANCE_MASTER_API_KEY=
# BINANCE_MASTER_API_SECRET=
# BINANCE_SUB1_API_KEY=
# BINANCE_SUB1_API_SECRET=
# BINANCE_SUB2_API_KEY=
# BINANCE_SUB2_API_SECRET=

# Agent 2 trading/execution uses resolveBinanceCredentials (same env vars as above).
# Optional: master | sub1 | sub2 (default master). Example: AGENT2_BINANCE_ACCOUNT=sub1
# AGENT2_BINANCE_ACCOUNT=master

# Supabase (for Agent 1 settings persistence)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# Throttle / spike backtest tuning (optional)
# BINANCE_FUTURES_WEIGHT_BUDGET_RATIO=0.45
# BINANCE_FUTURES_MIN_REQUEST_GAP_MS=25
# Local candle cache (see Backtest → Local candle cache): spike backtests read JSON from disk when enabled.
# SPIKE_TPSL_USE_LOCAL_CANDLES=true
# LOCAL_CANDLE_DIR=data/local-candles
# SPIKE_TPSL_V3_CONCURRENCY=2
# SPIKE_TPSL_V3_MAX_SYMBOLS=80
# SPIKE_TPSL_V3_PAGE_DELAY_MS=0

# 5m universe screener (Test Page): default max symbols 600, hard cap 800; parallel fetches.
# FIVEMIN_SCREENER_MAX_SYMBOLS=600
# FIVEMIN_SCREENER_CONCURRENCY=18
# Klines endTime pinning for Agent 1/3 scans (default on). Set to false to revert to unpinned "latest candle" fetches.
# FIVEMIN_SCREENER_KLINES_ENDTIME=
# Optional: ms floor for "late scan → previous bar" (default 90000). Capped per interval; usually leave unset.
# FIVEMIN_KLINES_LATE_HEAD_MS=90000
# Agent 1/3: default min available/wallet % when agent_settings.min_available_wallet_pct is unset (NULL). Per-agent
# value is set in the Agent 1 / Agent 3 UI (stored in Supabase). Set 0 to disable the headroom check.
# FUTURES_MIN_AVAILABLE_WALLET_PCT=30

# Agent 1/3 execution: max time after scan completes to open a trade (default 60000). Stale age from candle open =
# interval + (SPIKE_EXECUTION_TRADE_WINDOW_MS − agent_settings scan_seconds_before_close). Override fully with AGENT*_EXECUTION_MAX_SPIKE_AGE_MS.
# SPIKE_EXECUTION_TRADE_WINDOW_MS=60000

# Agent 1 automated 5m spike scan (requires Supabase + run supabase/agent1_spikes.sql). Omit or any value except false enables the scheduler.
# AGENT1_SCAN_SCHEDULER=false
# Agent 1 execution loop (requires BINANCE keys + run supabase/agent1_execution.sql)
# AGENT1_EXECUTION_ENABLED=false
# AGENT1_EXECUTION_POLL_MS=15000
# AGENT1_EXECUTION_MAX_SPIKES_PER_TICK=8
# Optional: max age (ms) from candle open before execution skips a spike (overrides SPIKE_EXECUTION_TRADE_WINDOW_MS math entirely).
# AGENT1_EXECUTION_MAX_SPIKE_AGE_MS=
# AGENT1_EXECUTION_SINGLE_WRITER=true
# AGENT1_EXECUTION_LOCK_NAME=agent1_execution_main
# AGENT1_EXECUTION_LOCK_TTL_SEC=90
# AGENT1_EXECUTION_WRITER_ID=gce-execution

# Agent 3 — down spikes → short (requires supabase/agent3_schema.sql; same Binance + lock pattern as Agent 1).
# AGENT3_SCAN_SCHEDULER=false
# AGENT3_EXECUTION_ENABLED=false
# AGENT3_EXECUTION_POLL_MS=15000
# AGENT3_EXECUTION_MAX_SPIKES_PER_TICK=8
# AGENT3_EXECUTION_MAX_SPIKE_AGE_MS= (same default as Agent 1 unless set)
# AGENT3_EXECUTION_SINGLE_WRITER=true
# AGENT3_EXECUTION_LOCK_NAME=agent3_execution_main
# AGENT3_EXECUTION_LOCK_TTL_SEC=90
# AGENT3_EXECUTION_WRITER_ID=gce-agent3

# Shadow simulation: scan / universe / spike tuning lives in Supabase table public.agent1_shadow_sim_config
# (run supabase/agent1_shadow_sim_config.sql). Read/write via API GET/PATCH /api/agents/agent1/shadow-sim-config.
# AGENT1_SHADOW_MARKET_WIDE=false
# AGENT1_SHADOW_SYMBOL=BLESSUSDT
# AGENT1_SHADOW_BARS=1000
# AGENT1_SHADOW_CONCURRENCY=18
# AGENT1_SHADOW_SCHEDULER=false
# Ongoing (eod) rows: default uses last replay bar close for unrealized %. true = poll Binance ticker (can diverge from sim).
# AGENT1_SHADOW_OPEN_MARK_LIVE=false
# AGENT1_SHADOW_SINGLE_WRITER=true
# AGENT1_SHADOW_LOCK_NAME=agent1_shadow_main
# AGENT1_SHADOW_LOCK_TTL_SEC=90
# AGENT1_SHADOW_WRITER_ID=gce-main

# Local-dev safety (recommended when production is using the same Supabase):
# AGENT1_SHADOW_SCHEDULER=false

# Agent 2 — spike scan + execution (requires supabase/agent2_schema.sql + same agent_runtime_locks as Agent 1 shadow).
# AGENT2_SCAN_SCHEDULER=false
# AGENT2_BOOT_SCAN=false
# AGENT2_EXECUTION_ENABLED=false
# AGENT2_EXECUTION_POLL_MS=15000
# Only one instance should run scans / execution against the same Supabase + keys (same pattern as Agent 1 execution).
# AGENT2_SCAN_SINGLE_WRITER=true
# AGENT2_SCAN_LOCK_NAME=agent2_scan_main
# AGENT2_SCAN_LOCK_TTL_SEC=300
# AGENT2_SCAN_WRITER_ID=gce-agent2
# AGENT2_EXECUTION_SINGLE_WRITER=true
# AGENT2_EXECUTION_LOCK_NAME=agent2_execution_main
# AGENT2_EXECUTION_LOCK_TTL_SEC=90
# AGENT2_EXECUTION_WRITER_ID=gce-agent2
